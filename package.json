{
  "name": "coworking-space-platform",
  "version": "1.0.0",
  "description": "Co-Working Space Booking Platform with User and Admin interfaces",
  "main": "backend/server.js",
  "scripts": {
    "backend": "cd backend && node server.js",
    "backend-dev": "cd backend && nodemon server.js",
    "user-frontend": "cd user-frontend && npx http-server -p 8080 -c-1 -o",
    "admin-frontend": "cd admin-frontend && npx http-server -p 8081 -c-1 -o",
    "install-backend": "cd backend && npm install",
    "start-all": "concurrently \"npm run backend\" \"npm run user-frontend\" \"npm run admin-frontend\""
  },
  "keywords": ["coworking", "booking", "workspace", "platform"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
